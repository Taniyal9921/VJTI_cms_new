# Copy this file to `.env` in the same folder (backend/.env). Without `.env`, the app uses
# built-in defaults (cms_user / college_cms on 127.0.0.1) — those only work after you create
# that user+DB (see scripts/setup_postgres.sql) OR use Docker (../docker-compose.yml).

# PostgreSQL — must match a real role + database on your server.
# Special characters in password must be URL-encoded (@ → %40, # → %23, etc.)
DATABASE_URL=postgresql://cms_user:cms_pass@127.0.0.1:5432/college_cms

# Example using the built-in superuser instead:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/college_cms

# JWT — use a long random secret in production
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated origins for the React app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
