# Dev: leave unset — axios baseURL is `/api` and Vite proxies to http://127.0.0.1:8000 (see vite.config.ts).
# Direct to FastAPI (no proxy): include the /api prefix.
#   VITE_API_URL=http://127.0.0.1:8000/api
# Host only also works (we auto-append /api in src/api/client.ts):
#   VITE_API_URL=http://127.0.0.1:8000
